{
  "permissions": {
    "allow": [
      "Bash(git ls-tree:*)",
      "Bash(rustc:*)",
      "Bash(curl:*)",
      "Bash(cargo metadata:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo tree:*)",
      "Bash(python3:*)",
      "Bash(./make.sh build:*)",
      "Bash(xcodebuild:*)",
      "Bash(./make.sh deploy:*)",
      "mcp__drawthings__check_status",
      "mcp__drawthings__get_config",
      "mcp__drawthings__generate_image",
      "Bash(/usr/bin/date:*)",
      "Bash(./scripts/claude-usage.sh:*)",
      "Bash(cargo search:*)",
      "Bash(echo parse failed:*)",
      "Bash(lsof:*)",
      "Bash(pgrep:*)",
      "Bash(grep:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat > /tmp/jc-hook-sessionstart-test.json"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST http://127.0.0.1:64555/jc-hook/session-start -H 'Content-Type: application/json' -d @-",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat > /tmp/jc-hook-sessionend-test.json"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST http://127.0.0.1:64555/jc-hook/session-end -H 'Content-Type: application/json' -d @-",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:64555/jc-hook/prompt-submit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:64555/jc-hook/stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:64555/jc-hook/notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:64555/jc-hook/permission"
          }
        ]
      }
    ]
  }
}